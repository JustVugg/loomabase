{
  "name": "@loomabase/client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client primitives for Loomabase offline-first sync.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.mjs",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "offline-first",
    "crdt",
    "sqlite",
    "postgresql",
    "supabase",
    "sync"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": ">=5.5"
  }
}
